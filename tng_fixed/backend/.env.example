NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Cloudflare Pages / frontend público
FRONTEND_URL=https://technetgame-site.pages.dev
ALLOWED_ORIGIN=https://technetgame-site.pages.dev,https://technetgame.com.br,https://www.technetgame.com.br
ENABLE_CORS=true
TRUST_PROXY=true

# Serviço Python / IA
AI_URL=https://SEU-PROJETO-AI.up.railway.app
AI_TIMEOUT_MS=45000

# Site local servido pelo Node apenas para testes locais
PUBLIC_SITE_DIR=../../site

# Tradução externa (sem LibreTranslate local)
TRANSLATION_ENABLED=true
TRANSLATION_PROVIDER=libretranslate
TRANSLATION_API_URL=https://libretranslate.de/translate
TRANSLATION_API_KEY=
TRANSLATION_TARGET=pt
TRANSLATION_SOURCE_MODE=auto
TRANSLATION_CACHE_TTL_DAYS=45
TRANSLATION_REQUEST_TIMEOUT_MS=7000
TRANSLATION_MAX_TEXT_LENGTH=420

# Cache / jobs
CACHE_DIR=./data/cache
REQUEST_TIMEOUT_MS=15000
IMAGE_FETCH_TIMEOUT_MS=5000
IMAGE_CACHE_TTL_MS=86400000
IMAGE_ENRICH_LIMIT=8
REFRESH_CRON=*/15 * * * *
REFRESH_TIMEZONE=America/Sao_Paulo
REFRESH_TOKEN=troque-esta-chave-forte
ALLOW_LOCAL_REFRESH_WITHOUT_TOKEN=false
USER_AGENT=TechNetGameBot/1.0 (+https://technetgame.com.br)

# APIs opcionais
SUPABASE_URL=
SUPABASE_ANON_KEY=
RAWG_API_KEY=
RAWG_API_BASE=https://api.rawg.io/api
NEWSAPI_KEY=
NEWSAPI_BASE=https://newsapi.org/v2/everything
GAME_NEWS_CACHE_TTL_MS=1800000
GAME_NEWS_REQUEST_TIMEOUT_MS=10000
GAME_NEWS_PAGE_SIZE=3
GAME_NEWS_FETCH_MULTIPLIER=4
