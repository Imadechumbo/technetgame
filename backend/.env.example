PORT=3000
HOST=0.0.0.0
NODE_ENV=production
SITE_DOMAIN=technetgame.com.br
SITE_URL=https://technetgame.com.br
API_URL=https://api.technetgame.com.br
ALLOWED_ORIGIN=https://www.technetgame.com.br,https://technetgame.com.br,https://api.technetgame.com.br
ENABLE_CORS=true
TRUST_PROXY=true
CACHE_DIR=/var/www/technetgame/shared/backend-cache
REQUEST_TIMEOUT_MS=15000
IMAGE_FETCH_TIMEOUT_MS=5000
IMAGE_CACHE_TTL_MS=86400000
IMAGE_ENRICH_LIMIT=8
REFRESH_CRON=*/15 * * * *
REFRESH_TIMEZONE=America/Sao_Paulo
REFRESH_TOKEN=troque-esta-chave-forte
ALLOW_LOCAL_REFRESH_WITHOUT_TOKEN=false
USER_AGENT=TechNetGameBot/1.0 (+https://www.technetgame.com.br)

# LibreTranslate hospedado
TRANSLATION_ENABLED=true
TRANSLATION_PROVIDER=libretranslate
TRANSLATION_API_URL=http://127.0.0.1:5000/translate
TRANSLATION_API_KEY=
TRANSLATION_TARGET=pt
TRANSLATION_SOURCE_MODE=auto
TRANSLATION_CACHE_TTL_DAYS=45
TRANSLATION_REQUEST_TIMEOUT_MS=7000
TRANSLATION_MAX_TEXT_LENGTH=420

MEDIA_CACHE_TTL_MS=604800000
MEDIA_REQUEST_TIMEOUT_MS=12000
RAWG_API_KEY=
RAWG_API_BASE=https://api.rawg.io/api

NEWSAPI_KEY=
NEWSAPI_BASE=https://newsapi.org/v2/everything
GAME_NEWS_CACHE_TTL_MS=1800000
GAME_NEWS_REQUEST_TIMEOUT_MS=10000
GAME_NEWS_PAGE_SIZE=3

GAME_NEWS_FETCH_MULTIPLIER=4

PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=
SERPAPI_ACCESS_KEY=
